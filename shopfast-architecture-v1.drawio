        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#FF0000;strokeWidth=2;dashed=1;" edge="1" parent="1" source="lambda" target="s3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5label" value="raw card data leaks into&#10;log query strings (Req 3.3 gap)" style="text;html=1;fontSize=10;fontColor=#FF0000;fontStyle=1" vertex="1" parent="1">
