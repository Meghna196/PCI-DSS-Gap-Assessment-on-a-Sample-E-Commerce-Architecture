<mxfile host="app.diagrams.net" modified="2026-07-05T00:00:00.000Z" agent="draw.io" version="24.0.0" type="device">
  <diagram name="ShopFast Architecture v1" id="shopfast-arch-v1">
    <mxGraphModel dx="1400" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Legend -->
        <mxCell id="legend" value="ShopFast E-Commerce Architecture (v1)&#10;Red dashed boundary = Cardholder Data Environment (CDE)" style="text;html=1;align=left;verticalAlign=top;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="600" height="50" as="geometry" />
        </mxCell>

        <!-- Customer Browser -->
        <mxCell id="browser" value="Customer Browser" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- CDE Boundary (drawn first so it sits behind) -->
        <mxCell id="cdeBoundary" value="Cardholder Data Environment (CDE)" style="rounded=0;whiteSpace=wrap;html=1;dashed=1;dashPattern=8 4;strokeColor=#FF0000;strokeWidth=3;fillColor=none;verticalAlign=top;align=left;fontColor=#FF0000;fontStyle=1;spacingLeft=10;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="260" y="90" width="1080" height="560" as="geometry" />
        </mxCell>

        <!-- Frontend -->
        <mxCell id="frontend" value="Next.js Frontend&#10;(Vercel-like Edge Platform)&#10;Custom HTML checkout form&#10;collects raw card number" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="300" y="120" width="220" height="90" as="geometry" />
        </mxCell>

        <!-- API Gateway -->
        <mxCell id="apigw" value="AWS API Gateway" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="600" y="120" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- Lambda -->
        <mxCell id="lambda" value="Node.js REST API&#10;(AWS Lambda)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="850" y="120" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- RDS -->
        <mxCell id="rds" value="AWS RDS (PostgreSQL)&#10;orders table:&#10;card_last4, card_number (full PAN, at rest, unencrypted)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="850" y="250" width="220" height="100" as="geometry" />
        </mxCell>

        <!-- S3 logs -->
        <mxCell id="s3" value="S3 Bucket&#10;Transaction logs&#10;(raw card data leaked&#10;via query strings)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="1120" y="250" width="200" height="90" as="geometry" />
        </mxCell>

        <!-- CloudWatch -->
        <mxCell id="cloudwatch" value="CloudWatch Logs&#10;(exist, NOT reviewed,&#10;no alerting)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="850" y="400" width="200" height="80" as="geometry" />
        </mxCell>

        <!-- Admin Portal -->
        <mxCell id="admin" value="Admin Portal&#10;Username + password only&#10;(no MFA)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="300" y="400" width="200" height="80" as="geometry" />
        </mxCell>

        <!-- Third-party plugins -->
        <mxCell id="plugins" value="3x Third-Party Checkout Plugins&#10;(no verified SAQ-A)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="300" y="530" width="220" height="70" as="geometry" />
        </mxCell>

        <!-- VPC boundary note -->
        <mxCell id="vpcNote" value="No network segmentation between CDE and rest of AWS VPC (Req 1.3 gap)" style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontColor=#FF0000;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="600" y="560" width="500" height="40" as="geometry" />
        </mxCell>

        <!-- Edges: data flow -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#000000;strokeWidth=2;" edge="1" parent="1" source="browser" target="frontend">
